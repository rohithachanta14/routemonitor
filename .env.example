# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://routemonitor:password@localhost:5432/routemonitor
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── InfluxDB 2.0 ─────────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-auth-token
INFLUXDB_ORG=myorg
INFLUXDB_BUCKET=bgp_metrics

# ─── BMP Server ───────────────────────────────────────────────────────────────
BMP_LISTEN_HOST=0.0.0.0
BMP_LISTEN_PORT=179

# ─── Alert Channels ───────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# ─── Anomaly Detection ────────────────────────────────────────────────────────
ANOMALY_BASELINE_DAYS=7
ANOMALY_Z_SCORE_THRESHOLD=3.0
ANOMALY_DEDUP_WINDOW_SECONDS=300
